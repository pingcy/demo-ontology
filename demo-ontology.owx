    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Customer -->

    <owl:Class rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Customer"/>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#ExpediteEligibleOrder -->

    <owl:Class rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#ExpediteEligibleOrder">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#ReadyToShipOrder"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#hasCustomer"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#VIPCustomer"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#InventoryAllocation -->

