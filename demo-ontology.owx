    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#hasAllocation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#hasAllocation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#InventoryAllocation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#hasCustomer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#hasCustomer">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Customer"/>
        <rdfs:comment>订单由该客户下单</rdfs:comment>
    </owl:ObjectProperty>
    


