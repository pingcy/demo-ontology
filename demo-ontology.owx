        <orders-manager-ontology:availableQty rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</orders-manager-ontology:availableQty>
        <orders-manager-ontology:qcPassed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</orders-manager-ontology:qcPassed>
    </owl:NamedIndividual>
    


