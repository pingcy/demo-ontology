        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#requiredQty -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#requiredQty">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
