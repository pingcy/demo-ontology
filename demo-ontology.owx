    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#order_A1024">
        <rdf:type rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
        <orders-manager-ontology:hasAllocation rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#alloc_for_A1024"/>
        <orders-manager-ontology:hasCustomer rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#customer_normal"/>
        <orders-manager-ontology:requiredQty rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</orders-manager-ontology:requiredQty>
    </owl:NamedIndividual>
    


