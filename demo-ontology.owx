    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#dependsOn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#dependsOn">
