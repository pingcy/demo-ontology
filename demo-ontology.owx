    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order -->

    <owl:Class rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#ReadyToShipOrder -->

    <owl:Class rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#ReadyToShipOrder">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#hasAllocation"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#InventoryAllocation"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#qcPassed"/>
                                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Order"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Shipment -->

    <owl:Class rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Shipment"/>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#VIPCustomer -->

    <owl:Class rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#VIPCustomer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#Customer"/>
    </owl:Class>
    


