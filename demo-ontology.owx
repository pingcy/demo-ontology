    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#availableQty -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#availableQty">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#InventoryAllocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#qcPassed -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pingcy/ontologies/orders-manager-ontology#qcPassed">
